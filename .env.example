# Redis (use Docker: docker run -d -p 6379:6379 --name srs-redis redis)
REDIS_HOST=127.0.0.1
REDIS_PORT=6379

# CV Worker
CAMERA_URLS=demo_video.mp4
FRAME_SAMPLE_INTERVAL=6
ONNX_MODEL_PATH=cv_worker/models/yolo11n.onnx
SNAPSHOT_DIR=snapshots
SNAPSHOT_TTL_HOURS=48

# Detection tuning (runtime, not baked into ONNX)
CONFIDENCE_THRESHOLD=0.35
NMS_IOU_THRESHOLD=0.45
PERSON_CLASS_ID=0

# Django
DJANGO_SECRET_KEY=change-me-in-production
DEBUG=True
ALLOWED_HOSTS=*

# Assignment weights (must sum to 1)
WEIGHT_PROXIMITY=0.5
WEIGHT_ZONE_LOAD=0.3
WEIGHT_SKILL_MATCH=0.2

# Task timeouts
ACK_TIMEOUT_SECONDS=45
MAX_REASSIGNMENTS=2
HYSTERESIS_WINDOW_SECONDS=60
